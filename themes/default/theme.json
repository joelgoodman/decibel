{
  "id": "default",
  "name": "Default Theme",
  "description": "The default theme for the CMS",
  "version": "1.0.0",
  "author": "StackBlitz",
  "settings": {
    "colors": {
      "primary": "#2563eb",
      "secondary": "#4f46e5",
      "accent": "#0ea5e9",
      "background": "#ffffff",
      "text": "#1f2937"
    },
    "typography": {
      "fontFamily": "system-ui, sans-serif",
      "headings": {
        "fontFamily": "system-ui, sans-serif",
        "fontWeight": "600"
      }
    },
    "spacing": {
      "unit": 4,
      "container": {
        "maxWidth": "1200px",
        "padding": "1rem"
      }
    },
    "borderRadius": "0.5rem",
    "boxShadow": "0 1px 3px 0 rgb(0 0 0 / 0.1)"
  }
}